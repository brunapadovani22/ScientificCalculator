<Window x:Class="CalculadoraCientifica.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculadora Científica" Height="560" Width="380"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Visor principal -->
        <TextBox x:Name="Display" 
                 Grid.Row="0" 
                 Height="60" 
                 FontSize="24" 
                 HorizontalContentAlignment="Right" 
                 VerticalContentAlignment="Center" 
                 Padding="10"
                 Margin="0,0,0,15"
                 Background="White"/>

        <!-- Grade de Botões completa -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Linha 0: Ações e Divisão com '÷' -->
            <Button Grid.Row="0" Grid.Column="0" Content="DEG" Tag="toggle_angle" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="0" Grid.Column="1" Content="C" Tag="clear" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="0" Grid.Column="2" Content="⌫" Tag="backspace" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="0" Grid.Column="3" Content="÷" Tag="÷" Click="Button_Click" Margin="2"/>

            <!-- Linha 1: Trigonometria e Multiplicação com '×' -->
            <Button Grid.Row="1" Grid.Column="0" Content="sin" Tag="sin" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="1" Grid.Column="1" Content="cos" Tag="cos" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="1" Grid.Column="2" Content="tan" Tag="tan" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="1" Grid.Column="3" Content="×" Tag="×" Click="Button_Click" Margin="2"/>

            <!-- Linha 2: Logaritmos, Raiz e Subtração -->
            <Button Grid.Row="2" Grid.Column="0" Content="ln" Tag="ln" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="2" Grid.Column="1" Content="log" Tag="log" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="2" Grid.Column="2" Content="√" Tag="sqrt" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="2" Grid.Column="3" Content="-" Tag="-" Click="Button_Click" Margin="2"/>

            <!-- Linha 3: Potência, Fatorial, Pi e Adição -->
            <Button Grid.Row="3" Grid.Column="0" Content="x^y" Tag="^" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="3" Grid.Column="1" Content="n!" Tag="!" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="3" Grid.Column="2" Content="π" Tag="π" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="3" Grid.Column="3" Content="+" Tag="+" Click="Button_Click" Margin="2"/>

            <!-- Linha 4: Teclado Numérico (7, 8, 9, parêntese) -->
            <Button Grid.Row="4" Grid.Column="0" Content="7" Tag="7" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="4" Grid.Column="1" Content="8" Tag="8" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="4" Grid.Column="2" Content="9" Tag="9" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="4" Grid.Column="3" Content="(" Tag="(" Click="Button_Click" Margin="2"/>

            <!-- Linha 5: Teclado Numérico (4, 5, 6, parêntese) -->
            <Button Grid.Row="5" Grid.Column="0" Content="4" Tag="4" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="5" Grid.Column="1" Content="5" Tag="5" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="5" Grid.Column="2" Content="6" Tag="6" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="5" Grid.Column="3" Content=")" Tag=")" Click="Button_Click" Margin="2"/>

            <!-- Linha 6: Teclado Numérico (1, 2, 3, constante e) -->
            <Button Grid.Row="6" Grid.Column="0" Content="1" Tag="1" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="6" Grid.Column="1" Content="2" Tag="2" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="6" Grid.Column="2" Content="3" Tag="3" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="6" Grid.Column="3" Content="e" Tag="e" Click="Button_Click" Margin="2"/>

            <!-- Linha 7: Teclado Numérico (0, vírgula e igual) -->
            <Button Grid.Row="7" Grid.Column="0" Content="0" Tag="0" Click="Button_Click" Margin="2"/>
            <Button Grid.Row="7" Grid.Column="1" Content="," Tag="," Click="Button_Click" Margin="2"/>
            <Button Grid.Row="7" Grid.Column="2" Grid.ColumnSpan="2" Content="=" Tag="calculate" Click="Button_Click" Margin="2" Background="#2563EB" Foreground="White"/>
        </Grid>
    </Grid>
</Window>